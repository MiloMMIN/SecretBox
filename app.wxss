/** app.wxss **/
page {
  /* 🎨 核心配色：柔和、治愈、安全 */
  --primary-green: #79968B;       /* 主色调：雾绿 */
  --primary-green-light: #EDF3EE; /* 浅雾绿背景 */
  --primary-green-dark: #5D786F;  /* 深雾绿强调 */
  
  --bg-color: #F5EFE6;            /* 全局背景：暖米白 */
  --surface-color: #FFFBF7;       /* 卡片背景 */
  
  --text-main: #42524C;           /* 主文字：灰绿 */
  --text-secondary: #7B6B5C;      /* 次要文字 */
  --text-placeholder: #B7A999;    /* 占位符颜色 */
  
  --accent-orange: #D89E6E;       /* 强调色：暖砂橙 */
  --accent-red: #B86A58;          /* 警告/错误 */
  
  /* 📐 形状与间距 */
  --radius-sm: 12rpx;
  --radius-md: 24rpx;             /* 卡片圆角 */
  --radius-lg: 40rpx;             /* 按钮圆角 */
  --radius-round: 999rpx;
  
  --spacing-xs: 10rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 30rpx;
  --spacing-lg: 40rpx;
  
  /* 🌑 阴影：柔和弥散 */
  --shadow-sm: 0 4rpx 12rpx rgba(111, 89, 65, 0.05);
  --shadow-md: 0 12rpx 28rpx rgba(111, 89, 65, 0.08);
  --shadow-lg: 0 20rpx 56rpx rgba(111, 89, 65, 0.1);

  background-color: var(--bg-color);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 40rpx;
} 

/* 通用卡片样式 */
.card {
  background: var(--surface-color);
  border-radius: var(--radius-md);
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.995);
  box-shadow: var(--shadow-sm); /* 点击时阴影收缩 */
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-green), var(--primary-green-dark));
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(102, 187, 106, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: translateY(2rpx);
}

.btn-secondary {
  background: white;
  color: var(--primary-green);
  border: 2rpx solid var(--primary-green);
}

/* 辅助类 */
.text-center { text-align: center; }
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.spacer { height: 20rpx; }

/* 徽章/标签 */
.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  display: inline-block;
}

.tag-green { background: var(--primary-green-light); color: var(--primary-green-dark); }
.tag-grey { background: #ECEFF1; color: var(--text-secondary); }
