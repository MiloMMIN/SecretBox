<view
  class="welcome-page {{entering ? 'is-entering' : ''}}"
  style="padding-top: {{topPadding}}px; padding-bottom: {{bottomPadding}}px;"
>
  <view class="page-grain"></view>
  <view class="ambient ambient-earth"></view>
  <view class="ambient ambient-moss"></view>
  <view class="ambient ambient-mist"></view>
  <view class="tunnel-ring tunnel-ring-outer"></view>
  <view class="tunnel-ring tunnel-ring-middle"></view>
  <view class="tunnel-ring tunnel-ring-inner"></view>
  <view class="enter-shadow"></view>

  <view class="main-stage">
    <view class="hero-copy">
      <view class="hero-title">智梦心坊</view>
      <view class="hero-subtitle">
        先在门口慢慢转一圈，再把想说的话轻轻放进去。
      </view>
    </view>

    <view class="portal-stage" bindtap="enterApp">
      <view class="orbit-track orbit-track-primary">
        <view
          wx:for="{{orbitPanels}}"
          wx:key="id"
          class="orbit-card orbit-card-{{item.slot}}"
        >
          <view class="orbit-card-body">
            <view class="orbit-card-sheet">
              <view class="orbit-card-tag">{{item.tag}}</view>
              <view class="orbit-card-title">{{item.title}}</view>
              <view class="orbit-card-desc">{{item.desc}}</view>
              <view class="orbit-card-lines">
                <view class="line short"></view>
                <view class="line medium"></view>
                <view class="line long"></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="orbit-track orbit-track-secondary">
        <view class="orbit-node orbit-node-a"></view>
        <view class="orbit-node orbit-node-b"></view>
        <view class="orbit-node orbit-node-c"></view>
        <view class="orbit-node orbit-node-d"></view>
      </view>

      <view class="portal-core">
        <view class="core-shadow"></view>
        <view class="core-halo"></view>
        <view class="core-ring core-ring-outer"></view>
        <view class="core-ring core-ring-inner"></view>

        <view class="logo-shell">
          <view class="logo-frame">
            <image
              class="logo-image"
              src="../../assets/images/college-logo.png"
              mode="aspectFit"
            />
          </view>
        </view>
      </view>
    </view>

    <view class="footer-copy">
      <view class="footer-title">让想说的话，先轻一点落下来</view>
      <view class="footer-desc">
        每个人都是世界的一个春天
      </view>
    </view>

    <button
      class="enter-button"
      bindtap="enterApp"
      disabled="{{entering || checkingLogin || loginLoading}}"
    >
      {{entering ? '正在进入树洞深处' : '轻触，进入树洞深处'}}
    </button>

    <button
      class="reserve-button"
      bindtap="goToAppointment"
      disabled="{{entering || checkingLogin || loginLoading}}"
    >
      见面，来到树下相约
    </button>
  </view>

  <view wx:if="{{showLoginGate && !checkingLogin}}" class="login-gate" bindtap="hideLoginPanel">
    <view class="login-panel" catchtap="noop">
      <view class="login-panel-tag">欢迎来到智心树洞</view>
      <view class="login-panel-title">请先登录，再进入树洞</view>
      <view class="login-panel-desc">未登录时不能投递、预约或查看个人记录。</view>
      <view wx:if="{{hasAdminInviteToken}}" class="admin-invite-hint">你是通过管理员分享链接进入的，登录后会自动开通管理员权限。</view>
      <view wx:if="{{hasTeacherInviteToken}}" class="admin-invite-hint">你是通过教师开通链接进入的，登录后会自动开通教师身份。</view>
      <input
        class="login-panel-input"
        type="nickname"
        value="{{nickName}}"
        maxlength="20"
        placeholder="请输入昵称"
        bindinput="onNicknameInput"
        bindconfirm="startLogin"
        confirm-type="done"
      />
      <button
        class="login-panel-button"
        bindtap="startLogin"
        loading="{{loginLoading}}"
        disabled="{{loginLoading}}"
      >
        {{loginLoading ? '登录中...' : '立即登录并进入'}}
      </button>
    </view>
  </view>
</view>
