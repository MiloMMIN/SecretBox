.welcome-page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding-left: 28rpx;
  padding-right: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.92) 0%, rgba(255, 248, 240, 0.96) 34%, #f8f3ea 100%);
}

.ambient {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(10rpx);
  opacity: 0.85;
}

.ambient-peach {
  top: 140rpx;
  right: -80rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(255, 203, 170, 0.72) 0%, rgba(255, 223, 203, 0.18) 72%, rgba(255, 223, 203, 0) 100%);
  animation: floatPeach 8s ease-in-out infinite;
}

.ambient-mint {
  left: -110rpx;
  bottom: 260rpx;
  width: 380rpx;
  height: 380rpx;
  background: radial-gradient(circle, rgba(185, 223, 204, 0.78) 0%, rgba(222, 242, 232, 0.16) 70%, rgba(222, 242, 232, 0) 100%);
  animation: floatMint 9s ease-in-out infinite;
}

.ambient-cream {
  top: 40%;
  left: 50%;
  width: 520rpx;
  height: 520rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(255, 255, 255, 0.9) 0%, rgba(255, 250, 244, 0.18) 72%, rgba(255, 250, 244, 0) 100%);
}

.hero-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  padding: 54rpx 34rpx 42rpx;
  border-radius: 44rpx;
  background: rgba(255, 253, 249, 0.84);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  box-shadow:
    0 20rpx 60rpx rgba(155, 125, 99, 0.1),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.78);
  display: flex;
  flex-direction: column;
  align-items: center;
  backdrop-filter: blur(18rpx);
  animation: cardIn 0.7s ease-out both;
}

.logo-shell {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  margin-top: 8rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-glow {
  position: absolute;
  width: 350rpx;
  height: 350rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 218, 195, 0.88) 0%, rgba(252, 238, 224, 0.45) 55%, rgba(252, 238, 224, 0) 78%);
  animation: glowPulse 4.6s ease-in-out infinite;
}

.logo-frame {
  position: relative;
  width: 310rpx;
  height: 310rpx;
  border-radius: 50%;
  padding: 30rpx;
  box-sizing: border-box;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.95), rgba(251, 244, 235, 0.9));
  box-shadow:
    0 20rpx 48rpx rgba(174, 140, 113, 0.16),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.88);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: floatLogo 4.8s ease-in-out infinite;
}

.logo-image {
  width: 100%;
  height: 100%;
}

.title-group {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  padding: 0 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.hero-title {
  color: #4d5b52;
  width: 100%;
  max-width: 100%;
  font-size: 76rpx;
  font-weight: 600;
  font-family: 'STKaiti', 'KaiTi', 'Kaiti SC', serif;
  text-align: center;
  letter-spacing: 2rpx;
  line-height: 1.18;
  word-break: break-word;
}

.hero-subtitle {
  color: #a1725d;
  width: 100%;
  max-width: 100%;
  font-size: 36rpx;
  font-family: 'STSong', 'Songti SC', serif;
  text-align: center;
  letter-spacing: 3rpx;
  line-height: 1.45;
  word-break: break-word;
}

.enter-button {
  width: 100%;
  max-width: 100%;
  margin-top: 48rpx;
  height: 92rpx;
  line-height: 92rpx;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7bb98b 0%, #6aa17b 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  box-shadow: 0 18rpx 36rpx rgba(106, 161, 123, 0.25);
}

.enter-button::after {
  border: none;
}

.enter-button[disabled] {
  opacity: 0.88;
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.98);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes floatLogo {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes glowPulse {
  0%,
  100% {
    transform: scale(0.96);
    opacity: 0.82;
  }

  50% {
    transform: scale(1.04);
    opacity: 1;
  }
}

@keyframes floatPeach {
  0%,
  100% {
    transform: translate3d(0, 0, 0);
  }

  50% {
    transform: translate3d(-20rpx, 18rpx, 0);
  }
}

@keyframes floatMint {
  0%,
  100% {
    transform: translate3d(0, 0, 0);
  }

  50% {
    transform: translate3d(24rpx, -18rpx, 0);
  }
}
