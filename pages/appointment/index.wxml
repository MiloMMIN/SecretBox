<view class="appointment-page">
  <view class="ambient ambient-one"></view>
  <view class="ambient ambient-two"></view>
  <view class="paper-noise"></view>

  <scroll-view scroll-y class="page-scroll">
    <view class="hero-panel">
      <view class="hero-header">
        <view class="hero-kicker">心坊预约</view>
        <view wx:if="{{canManageAppointments}}" class="hero-action {{showManagerView ? 'is-active' : ''}}" bindtap="toggleManagerView">
          <text>{{showManagerView ? '返回预约' : '预约管理'}}</text>
          <text class="hero-action-arrow">{{showManagerView ? '<' : '>'}}</text>
        </view>
      </view>
      <view class="hero-title">{{showManagerView ? '查看预约流转' : '预约智梦心坊'}}</view>
      <view class="hero-desc">{{showManagerView ? (hasAdminAccess ? '管理员可查看并处理全部预约，也能继续跟进自己相关的时段。' : '既能查看自己发起的预约，也能处理预约到自己的咨询时段。') : '每个人都能为你的世界带来一季春光'}}</view>
    </view>

    <block wx:if="{{!showManagerView}}">
    <view class="section-card calendar-card">
      <view class="section-head">
        <view>
          <view class="section-title">本月时段</view>
          <view class="section-subtitle">已预约的时间会自动锁定，避免多人同时占用空间。</view>
        </view>
      </view>

      <view class="month-bar">
        <view class="month-switch" bindtap="changeMonth" data-step="-1">‹</view>
        <view class="month-center">
          <view class="month-label">{{monthLabel}}</view>
          <view class="month-meta">{{selectedDateLabel || '轻点日期查看当天剩余时段'}}</view>
        </view>
        <view class="month-switch" bindtap="changeMonth" data-step="1">›</view>
      </view>

      <view class="week-row">
        <view class="week-item" wx:for="{{weekLabels}}" wx:key="*this">{{item}}</view>
      </view>

      <view class="day-grid">
        <view
          wx:for="{{monthDays}}"
          wx:key="dateKey"
          class="day-cell {{item.isCurrentMonth ? '' : 'is-out'}} {{item.isSelected ? 'is-selected' : ''}} {{item.isToday ? 'is-today' : ''}} {{item.isPast ? 'is-past' : ''}}"
          bindtap="pickDate"
          data-date="{{item.dateKey}}"
        >
          <view class="day-number">{{item.day}}</view>
          <view wx:if="{{item.count > 0}}" class="day-badge">{{item.count}}</view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view>
          <view class="section-title">预约老师</view>
          <view class="section-subtitle">先选一位想谈话的老师，再锁定时间。</view>
        </view>
      </view>

      <scroll-view scroll-x class="teacher-scroll" enable-flex="true">
        <view class="teacher-list">
          <view
            wx:for="{{teachers}}"
            wx:key="id"
            class="teacher-item {{form.teacherId === item.id ? 'is-active' : ''}}"
            bindtap="selectTeacher"
            data-id="{{item.id}}"
            data-name="{{item.name}}"
          >
            <image
              wx:if="{{item.avatar && !item.avatarError}}"
              class="teacher-avatar"
              src="{{item.avatar}}"
              mode="aspectFill"
              binderror="onTeacherImageError"
              data-id="{{item.id}}"
            ></image>
            <view wx:else class="teacher-avatar teacher-avatar-fallback">{{item.avatarText}}</view>
            <view class="teacher-name">{{item.name}}</view>
            <view class="teacher-desc">{{item.desc}}</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view>
          <view class="section-title">填写预约信息</view>
          <view class="section-subtitle">{{selectedDateLabel}}</view>
          <view wx:if="{{form.teacherName}}" class="picked-teacher">{{form.teacherName}}</view>
        </view>
      </view>

      <view class="field-list">
        <view class="field-item">
          <view class="field-label">预约人姓名</view>
          <input
            class="field-input"
            placeholder="请输入姓名"
            maxlength="20"
            value="{{form.studentName}}"
            bindinput="onStudentNameInput"
          />
        </view>

        <view class="field-item">
          <view class="field-label">预约人班级</view>
          <input
            class="field-input"
            placeholder="例如：23计应2班"
            maxlength="32"
            value="{{form.studentClass}}"
            bindinput="onStudentClassInput"
          />
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view>
          <view class="section-title">选择时间</view>
          <view class="section-subtitle">默认每次半小时，可预约时间为 8:00-11:00、14:00-16:00。</view>
          <view class="slot-picked-date">{{slotDisplayText}}</view>
        </view>
        <view class="slot-summary">已占用 {{selectedDayAppointments.length}} / {{timeSlots.length}}</view>
      </view>

      <view class="slot-grid">
        <view
          wx:for="{{timeSlots}}"
          wx:key="start"
          class="slot-card {{item.occupied ? 'is-occupied' : ''}} {{item.selected ? 'is-selected' : ''}} {{item.expired ? 'is-expired' : ''}}"
          bindtap="selectSlot"
          data-start="{{item.start}}"
          data-occupied="{{item.occupied}}"
          data-expired="{{item.expired}}"
        >
          <view class="slot-time">{{item.start}} - {{item.end}}</view>
          <view class="slot-state">{{item.expired ? '已过时' : (item.occupied ? '已被占用' : (item.selected ? '已选择' : '可预约'))}}</view>
          <view class="slot-meta">{{item.expired ? '请改约其他时段' : (item.occupied ? item.teacherName : '30 分钟面谈')}}</view>
        </view>
      </view>

      <view wx:if="{{selectedDayAppointments.length > 0}}" class="occupied-panel">
        <view class="occupied-title">当天已占用</view>
        <view wx:for="{{selectedDayAppointments}}" wx:key="id" class="occupied-row">
          <text class="occupied-time">{{item.slotStart}} - {{item.slotEnd}}</text>
          <text class="occupied-teacher">{{item.teacherName}}</text>
        </view>
      </view>
    </view>

    <view class="section-card my-appointments-card">
      <view class="section-head">
        <view>
          <view class="section-title">{{isTeacher ? '我发起的预约' : '我的预约'}}</view>
          <view class="section-subtitle">{{isTeacher ? '这里会保留你发起过的预约记录，并在开始前允许取消。' : '你可以在这里查看自己的预约记录，并在开始前取消。'}}</view>
        </view>
        <view class="slot-summary">{{myAppointments.length}} 条</view>
      </view>

      <view wx:if="{{!isLoggedIn}}" class="appointment-empty">登录后即可查看自己的预约记录。</view>
      <view wx:elif="{{myAppointmentsLoading}}" class="appointment-empty">预约记录加载中...</view>
      <block wx:elif="{{myAppointments.length > 0}}">
        <view wx:for="{{myAppointments}}" wx:key="id" class="appointment-record">
          <view class="appointment-record-top">
            <view class="appointment-record-teacher">{{item.teacherName}}</view>
            <view class="appointment-record-status {{item.status}}">{{item.statusText}}</view>
          </view>
          <view class="appointment-record-time">{{item.date}} {{item.slotStart}} - {{item.slotEnd}}</view>
          <view class="appointment-record-meta">{{item.studentClass}} {{item.studentName}}</view>
          <view wx:if="{{item.cancelReason}}" class="appointment-record-note">取消说明：{{item.cancelReason}}</view>
          <view wx:if="{{item.cancelledAt}}" class="appointment-record-note">取消时间：{{item.cancelledAt}}</view>
          <button wx:if="{{item.canCancel}}" class="appointment-record-btn" bindtap="cancelAppointment" data-id="{{item.id}}" disabled="{{cancellingAppointmentId === item.id}}">{{cancellingAppointmentId === item.id ? '取消中...' : '取消预约'}}</button>
        </view>
      </block>
      <view wx:else class="appointment-empty">暂时还没有预约记录。</view>
    </view>

    <view class="submit-wrap">
      <button class="submit-btn" bindtap="submitAppointment" disabled="{{submitting}}">
        {{submitting ? '正在提交预约' : '确认预约'}}
      </button>
    </view>
    </block>

    <block wx:elif="{{showManagerView}}">
      <view class="manager-tab-row" wx:if="{{managerTabs.length > 0}}">
        <view wx:for="{{managerTabs}}" wx:key="key" class="manager-tab-pill {{managerCurrentTab === item.key ? 'is-active' : ''}}" bindtap="switchManagerTab" data-tab="{{item.key}}">
          {{item.label}} · {{item.count}}
        </view>
      </view>

      <view class="section-card">
        <view class="section-head">
          <view>
            <view class="section-title">{{managerCurrentTab === 'assigned' ? '预约我的' : (managerCurrentTab === 'all' ? '全部预约' : '我发起的预约')}}</view>
            <view class="section-subtitle">{{managerCurrentTab === 'assigned' ? '这些时段预约到了你，开始前都可以取消。' : (managerCurrentTab === 'all' ? '管理员可查看并处理所有人的预约记录。' : '这里展示你本人发起过的预约记录。')}}</view>
          </view>
        </view>

        <view wx:if="{{managerLoading}}" class="appointment-empty">加载中...</view>
        <block wx:elif="{{managerCurrentAppointments.length > 0}}">
          <view wx:for="{{managerCurrentAppointments}}" wx:key="id" class="appointment-record">
            <view class="appointment-record-top">
              <view class="appointment-record-teacher">{{managerCurrentTab === 'assigned' ? (item.studentName || '未填写姓名') : item.teacherName}}</view>
              <view class="appointment-record-status {{item.status}}">{{item.statusText}}</view>
            </view>
            <view class="appointment-record-time">{{item.date}} {{item.slotStart}} - {{item.slotEnd}}</view>
            <view class="appointment-record-meta" wx:if="{{managerCurrentTab !== 'assigned'}}">咨询老师：{{item.teacherName}}</view>
            <view class="appointment-record-meta" wx:if="{{managerCurrentTab !== 'created'}}">预约人：{{item.studentClass}} {{item.studentName}}</view>
            <view class="appointment-record-meta" wx:if="{{managerCurrentTab === 'all' && item.creatorName}}">发起账号：{{item.creatorName}}</view>
            <view wx:if="{{item.cancelReason}}" class="appointment-record-note">取消说明：{{item.cancelReason}}</view>
            <view wx:if="{{item.cancelledAt}}" class="appointment-record-note">取消时间：{{item.cancelledAt}}</view>
            <button wx:if="{{item.canCancel}}" class="appointment-record-btn" bindtap="cancelManagerAppointment" data-id="{{item.id}}" disabled="{{managerCancellingId === item.id}}">{{managerCancellingId === item.id ? '取消中...' : '取消预约'}}</button>
          </view>
        </block>
        <view wx:else class="appointment-empty">当前列表还没有预约记录。</view>
      </view>
    </block>
  </scroll-view>
</view>
