<!--pages/post/select_counselor.wxml-->
<view class="container">
  <view class="header">
    <view class="header-top">
      <text class="title">选择倾诉对象</text>
      <view class="home-btn" bindtap="goHome">
        <view class="back-icon">
          <view class="back-arrow"></view>
        </view>
      </view>
    </view>
    <text class="subtitle">可选择指定教师，也可投递到星空树洞由全体教师查看</text>
  </view>

  <view class="counselor-list">
    <block wx:for="{{counselors}}" wx:key="id">
      <view class="card counselor-card" bindtap="selectCounselor" data-id="{{item.id}}" data-name="{{item.name}}" data-avatar="{{item.avatar}}" data-avatar-text="{{item.avatarText}}">
        <view class="counselor-info">
          <image wx:if="{{item.avatar && !item.avatarError}}" class="avatar" src="{{item.avatar}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}"></image>
          <view wx:else class="avatar avatar-placeholder">{{item.avatarText}}</view>
          <view class="text-info">
            <view class="name-row">
              <text class="name-text">{{item.name}}</text>
              <text class="role" wx:if="{{!item.isTreeHole}}">教师</text>
              <text class="role tree-hole-tag" wx:else>纯树洞</text>
            </view>
            <view class="desc">{{item.desc}}</view>
          </view>
        </view>
        <view class="enter-btn">🌲 进入树洞</view>
      </view>
    </block>
  </view>
</view>
