/* pages/post/create.wxss */
.target-info {
  padding: 40rpx 40rpx 20rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
}

.target-name {
  color: var(--primary-green-dark);
  font-weight: bold;
  font-size: 32rpx;
  padding: 0 8rpx;
  background-color: var(--primary-green-light);
  border-radius: 8rpx;
  margin: 0 6rpx;
}

.form-card {
  padding: 40rpx;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  /* 拟物化：信纸效果 */
  background-image: linear-gradient(#F5F5F5 1px, transparent 1px);
  background-size: 100% 60rpx;
  background-position: 0 20rpx; /* 对齐线条 */
}

.content-input {
  width: 100%;
  height: 320rpx;
  font-size: 32rpx;
  line-height: 60rpx; /* 匹配信纸行高 */
  color: var(--text-main);
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-top: 20rpx;
}

.options-card {
  padding: 0 40rpx;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1px solid #F0F0F0;
}

.real-name-section {
  padding: 20rpx 0;
  border-bottom: 1px solid #F0F0F0;
  animation: fadeIn 0.3s ease-out;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  font-size: 28rpx;
  color: var(--text-main);
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #FF5252;
}

.input-field {
  background-color: #F5F7F5;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-main);
}

.option-item:last-child {
  border-bottom: none;
}

.option-label {
  display: flex;
  flex-direction: column;
}

.option-label text:first-child {
  font-size: 30rpx;
  color: var(--text-main);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.option-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.btn-area {
  padding: 60rpx 40rpx;
}

.submit-btn {
  background: linear-gradient(135deg, var(--primary-green), var(--primary-green-dark));
  color: white;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: bold;
  padding: 10rpx 0; /* 小程序 button padding 特殊 */
  box-shadow: 0 8rpx 20rpx rgba(102, 187, 106, 0.4);
  transition: all 0.3s;
}

.submit-btn[disabled] {
  background: #E0E0E0 !important;
  color: #999 !important;
  box-shadow: none;
}

.tips {
  padding: 0 50rpx 60rpx;
  font-size: 24rpx;
  color: var(--text-placeholder);
  line-height: 1.8;
  text-align: center;
}
