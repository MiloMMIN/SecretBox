/* pages/post/create.wxss */
.target-info {
  padding: 30rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
}

.target-name {
  color: var(--primary-green);
  font-weight: bold;
  font-size: 32rpx;
}

.form-card {
  padding: 30rpx;
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
}

.content-input {
  width: 100%;
  height: 240rpx;
  font-size: 30rpx;
  line-height: 1.5;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

.options-card {
  padding: 0 30rpx;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1px solid #f0f0f0;
}

.option-item:last-child {
  border-bottom: none;
}

.option-label {
  display: flex;
  flex-direction: column;
}

.option-label text:first-child {
  font-size: 30rpx;
  color: var(--text-main);
  margin-bottom: 6rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #999;
}

.btn-area {
  padding: 40rpx 30rpx;
}

.submit-btn {
  background-color: var(--primary-green);
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 10rpx 0;
}

.submit-btn[disabled] {
  background-color: #A5D6A7 !important;
  color: white !important;
}

.tips {
  padding: 0 40rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
