/* pages/post/select_counselor.wxss */
.header {
  padding: 60rpx 40rpx;
  background-color: var(--primary-green-light);
  color: var(--primary-green-dark);
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.8;
}

.counselor-list {
  padding: 30rpx 10rpx;
  margin-top: -40rpx; /* 上浮覆盖 Header */
}

.counselor-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx 30rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid transparent; /* 预留边框位置 */
}

.counselor-card:active {
  border-color: var(--primary-green);
  background-color: #FAFAFA;
}

.counselor-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background-color: #E0E0E0;
  margin-right: 30rpx;
  border: 4rpx solid white;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #90CAF9, #66BB6A);
  color: white;
  font-size: 38rpx;
  font-weight: 700;
}

.text-info {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.name-row {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.name-text {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-main);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 220rpx;
}

.role {
  font-size: 20rpx;
  color: var(--primary-green-dark);
  background-color: var(--primary-green-light);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  font-weight: 500;
}

.tree-hole-tag {
  background-color: #E3F2FD;
  color: #1976D2;
}

.desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.enter-btn {
  background-color: var(--primary-green);
  color: white;
  font-size: 24rpx;
  padding: 14rpx 24rpx;
  border-radius: 40rpx;
  margin-left: 8rpx;
  white-space: nowrap;
  box-shadow: 0 4rpx 10rpx rgba(102, 187, 106, 0.3);
  font-weight: 500;
  flex-shrink: 0;
}

