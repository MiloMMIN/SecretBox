/* pages/post/select_counselor.wxss */
.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(255, 248, 238, 0.94) 0%, rgba(240, 228, 211, 0.95) 32%, rgba(221, 204, 179, 0.96) 68%, #efe5d7 100%);
}

.header {
  padding: 60rpx 40rpx;
  background: linear-gradient(180deg, rgba(232, 242, 233, 0.86), rgba(240, 228, 211, 0.62));
  color: var(--primary-green-dark);
  border-bottom-left-radius: 36rpx;
  border-bottom-right-radius: 36rpx;
  box-shadow: 0 16rpx 36rpx rgba(111, 89, 65, 0.08);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #3d4c46;
  font-family: 'STKaiti', 'KaiTi', 'Kaiti SC', serif;
  display: block;
}

.home-btn {
  width: 72rpx;
  height: 72rpx;
  background: transparent;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-btn:active {
  background: rgba(121, 150, 139, 0.12);
  transform: scale(0.95);
}

.back-icon {
  width: 40rpx;
  height: 36rpx;
  position: relative;
}

.back-arrow {
  width: 24rpx;
  height: 24rpx;
  border-left: 4rpx solid var(--primary-green);
  border-bottom: 4rpx solid var(--primary-green);
  transform: rotate(45deg);
  position: absolute;
  left: 4rpx;
  top: 4rpx;
}

.back-arrow::after {
  content: '';
  position: absolute;
  width: 28rpx;
  height: 4rpx;
  background: var(--primary-green);
  transform: rotate(-45deg);
  top: 10rpx;
  left: -2rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.92;
  color: #756252;
  line-height: 1.7;
}

.counselor-list {
  padding: 30rpx 10rpx;
  margin-top: -40rpx; /* 上浮覆盖 Header */
}

.counselor-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx 30rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  background: rgba(255, 252, 247, 0.82);
  box-shadow: 0 18rpx 38rpx rgba(111, 89, 65, 0.08);
}

.counselor-card:active {
  border-color: rgba(121, 150, 139, 0.32);
  background-color: rgba(255, 250, 244, 0.92);
}

.counselor-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background-color: rgba(223, 214, 202, 0.86);
  margin-right: 30rpx;
  border: 4rpx solid white;
  box-shadow: 0 8rpx 18rpx rgba(111, 89, 65, 0.12);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #a8c2b1, #6b8a7d);
  color: white;
  font-size: 38rpx;
  font-weight: 700;
}

.text-info {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.name-row {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.name-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-main);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 220rpx;
}

.role {
  font-size: 20rpx;
  color: #5f7a6f;
  background-color: rgba(121, 150, 139, 0.14);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  font-weight: 500;
}

.tree-hole-tag {
  background-color: rgba(214, 166, 120, 0.16);
  color: #bc7d4a;
}

.desc {
  font-size: 24rpx;
  color: #7f6d5d;
  line-height: 1.5;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.enter-btn {
  background: linear-gradient(135deg, #79968b, #5d786f);
  color: white;
  font-size: 24rpx;
  padding: 14rpx 24rpx;
  border-radius: 40rpx;
  margin-left: 8rpx;
  white-space: nowrap;
  box-shadow: 0 8rpx 20rpx rgba(93, 120, 111, 0.2);
  font-weight: 500;
  flex-shrink: 0;
}

