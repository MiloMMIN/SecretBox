.pending-page {
  min-height: 100vh;
  padding: 48rpx 36rpx 80rpx;
  background: linear-gradient(180deg, #F2F5F8 0%, #FFFFFF 100%);
}

.pending-hero {
  padding: 48rpx 40rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #4A5A70 0%, #62768C 100%);
  color: #FFFFFF;
  box-shadow: 0 20rpx 40rpx rgba(74, 90, 112, 0.14);
}

.pending-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.pending-title {
  margin-top: 26rpx;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.3;
}

.pending-desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  opacity: 0.9;
}

.pending-card {
  margin-top: 32rpx;
  padding: 34rpx 32rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 14rpx 34rpx rgba(62, 82, 110, 0.08);
}

.pending-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #334357;
}

.pending-card-item {
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: #617386;
}

.primary-btn,
.secondary-btn {
  margin-top: 28rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 92rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #66BB6A 0%, #3F9C4B 100%);
  color: #FFFFFF;
  box-shadow: 0 14rpx 30rpx rgba(102, 187, 106, 0.24);
}

.secondary-btn {
  background: #FFFFFF;
  color: #516276;
  border: 2rpx solid #D8E0EA;
}
