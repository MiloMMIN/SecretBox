.container {
  padding: 24rpx;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #ECEFF1;
  color: #607D8B;
  font-size: 24rpx;
}

.filter-chip.active {
  background: #2E7D32;
  color: white;
}

.question-card,
.detail-card,
.reply-card {
  background: white;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(34, 68, 56, 0.06);
}

.question-top,
.question-meta,
.reply-top,
.reply-user-row,
.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.question-top {
  gap: 16rpx;
}

.question-type {
  padding: 6rpx 14rpx;
  border-radius: 18rpx;
  background: #E3F2FD;
  color: #1976D2;
  font-size: 22rpx;
}

.question-time,
.reply-time,
.question-meta {
  font-size: 22rpx;
  color: #90A4AE;
}

.question-content,
.reply-content {
  font-size: 30rpx;
  color: #37474F;
  line-height: 1.65;
  margin: 18rpx 0;
}

.question-latest {
  background: #F5F7F5;
  border-radius: 18rpx;
  padding: 16rpx 18rpx;
  color: #607D8B;
  font-size: 24rpx;
}

.question-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.review-status {
  padding: 6rpx 14rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
}

.review-status.pending {
  background: #FFF3E0;
  color: #FB8C00;
}

.review-status.approved {
  background: #E8F5E9;
  color: #43A047;
}

.review-status.rejected {
  background: #FFEBEE;
  color: #D32F2F;
}

.approve-btn,
.reject-btn,
.danger-btn {
  background: #FFEBEE;
  color: #D32F2F;
  border-radius: 32rpx;
  font-size: 24rpx;
  padding: 0 26rpx;
  line-height: 64rpx;
}

.approve-btn {
  background: #E8F5E9;
  color: #2E7D32;
}

.reject-btn {
  background: #FFF3E0;
  color: #EF6C00;
}

.danger-btn.full {
  margin-top: 10rpx;
}

.danger-btn.small {
  margin-top: 18rpx;
}

.detail-container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.detail-header {
  padding: 28rpx 30rpx 10rpx;
  background: white;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 700;
}

.close-btn {
  font-size: 40rpx;
  color: #90A4AE;
}

.detail-scroll {
  flex: 1;
  padding: 20rpx 24rpx 40rpx;
}

.detail-review-row,
.detail-review-actions {
  display: flex;
  align-items: center;
}

.detail-review-row {
  justify-content: space-between;
  margin-top: 12rpx;
  gap: 12rpx;
}

.detail-review-actions {
  gap: 12rpx;
}

.small-action {
  margin: 0;
  padding: 0 22rpx;
  line-height: 56rpx;
  font-size: 22rpx;
}

.detail-review-reason {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #FFF3E0;
  color: #B26A00;
  font-size: 24rpx;
  line-height: 1.6;
}

.reply-section {
  padding-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #607D8B;
  margin: 8rpx 0 18rpx;
}

.reply-name {
  font-size: 26rpx;
  color: #37474F;
  font-weight: 600;
}

.reply-role {
  margin-left: 12rpx;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
}

.reply-role.teacher {
  background: #E8F5E9;
  color: #43A047;
}

.reply-role.student {
  background: #ECEFF1;
  color: #607D8B;
}

.reply-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.reply-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
}

.empty-state {
  padding: 80rpx 20rpx;
  text-align: center;
  color: #90A4AE;
  font-size: 26rpx;
}

.list-status {
  text-align: center;
  color: #90A4AE;
  font-size: 24rpx;
  padding: 8rpx 0 24rpx;
}

.dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  padding: 32rpx;
}

.dialog-card {
  width: 100%;
  max-width: 620rpx;
  background: white;
  border-radius: 28rpx;
  padding: 36rpx 30rpx 30rpx;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #37474F;
  text-align: center;
}

.dialog-desc {
  margin: 18rpx 0 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #78909C;
  text-align: center;
}

.dialog-textarea {
  width: 100%;
  min-height: 180rpx;
  background: #F5F7F5;
  border-radius: 20rpx;
  padding: 20rpx 22rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #37474F;
  box-sizing: border-box;
}

.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dialog-btn {
  flex: 1;
  border-radius: 28rpx;
  font-size: 26rpx;
  line-height: 72rpx;
}

.dialog-btn.ghost {
  background: #ECEFF1;
  color: #607D8B;
}

.dialog-btn.solid {
  background: #FFF3E0;
  color: #EF6C00;
}
