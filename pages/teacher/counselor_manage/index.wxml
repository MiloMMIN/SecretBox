<view class="container">
  <scroll-view scroll-x class="profile-tabs">
    <view class="profile-tab {{currentIndex === index ? 'active' : ''}}" wx:for="{{profiles}}" wx:key="id" data-index="{{index}}" bindtap="switchProfile">
      {{item.nickName}}{{item.kind === 'invite' ? '·待开通' : ''}}
    </view>
  </scroll-view>

  <button class="add-btn" bindtap="createTeacherInvite">新增教师账号</button>

  <view wx:if="{{creating || editor.id}}" class="editor-card">
    <view class="avatar-area">
      <image wx:if="{{editor.avatarUrl}}" class="avatar" src="{{editor.avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="avatar placeholder">{{editor.nickName ? editor.nickName.slice(0, 1) : '教'}}</view>
      <button class="pick-avatar-btn" bindtap="chooseAvatar" disabled="{{uploading}}">{{uploading ? '上传中...' : (editor.avatarUrl ? '更换头像' : '设置头像')}}</button>
      <view class="hint avatar-hint">仅用于投递页展示，不影响账号头像。</view>
    </view>

    <view class="form-group">
      <view class="label">展示名字</view>
      <input class="input" value="{{editor.nickName}}" placeholder="请输入名字" bindinput="onNameInput" />
    </view>

    <view class="form-group">
      <view class="label">简介</view>
      <textarea class="textarea" value="{{editor.desc}}" maxlength="120" placeholder="请输入简介" bindinput="onDescInput"></textarea>
    </view>

    <view class="switch-row">
      <view>
        <view class="label">在投递页显示</view>
        <view class="hint">关闭后，该教师不会出现在投递对象列表中；如果该账号同时是管理员，也不会影响管理员权限。</view>
      </view>
      <switch checked="{{editor.isActive}}" bindchange="onActiveChange" color="#66BB6A"></switch>
    </view>

    <view wx:if="{{editor.kind === 'invite'}}" class="invite-box">
      <view class="label">教师分享链接</view>
      <button class="share-btn" open-type="share" disabled="{{!editor.shareToken || shareTokenLoading || saving}}">{{editor.shareToken ? '分享教师开通链接' : '准备教师分享链接中...'}}</button>
      <button class="copy-btn share-refresh-btn" bindtap="refreshInviteShareLink" disabled="{{shareTokenLoading || saving}}">{{shareTokenLoading ? '重新生成中...' : '重新生成分享链接'}}</button>
      <view class="hint">把这条分享链接发给教师本人，对方打开并登录后会自动开通教师身份。</view>
    </view>

    <button class="save-btn" bindtap="saveProfile" disabled="{{saving}}">{{saving ? '保存中...' : (creating ? '创建教师分享链接' : '保存教师设置')}}</button>

    <button wx:if="{{!creating && editor.kind === 'teacher'}}" class="delete-btn" bindtap="deleteTeacher" disabled="{{saving}}">移除教师身份</button>
  </view>

  <view wx:else class="empty-state">暂无可管理的教师账号</view>
</view>
