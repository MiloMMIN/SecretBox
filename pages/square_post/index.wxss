/* pages/post/post_square/index.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background-color: #FAFAFA;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-main, #333);
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary, #666);
}

.form-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 30rpx;
  position: relative;
}

.content-input {
  width: 100%;
  height: 400rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 20rpx;
}

.options-card {
  background: white;
  border-radius: 24rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 60rpx;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
}

.option-label {
  display: flex;
  flex-direction: column;
}

.label-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #999;
}

.submit-btn {
  background: linear-gradient(135deg, #66BB6A, #43A047);
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 20rpx rgba(102, 187, 106, 0.3);
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.submit-btn[disabled] {
  background: #ccc;
  box-shadow: none;
  color: #fff;
}