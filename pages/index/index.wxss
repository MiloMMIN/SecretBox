.pending-page {
  min-height: 100vh;
  padding: 48rpx 36rpx 80rpx;
  background: linear-gradient(180deg, #F3F7F4 0%, #FFFFFF 100%);
}

.pending-hero {
  padding: 48rpx 40rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #36474F 0%, #4E6A60 100%);
  color: #FFFFFF;
  box-shadow: 0 20rpx 40rpx rgba(54, 71, 79, 0.14);
}

.pending-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.pending-title {
  margin-top: 26rpx;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.3;
}

.pending-desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  opacity: 0.88;
}

.pending-card {
  margin-top: 32rpx;
  padding: 34rpx 32rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 14rpx 34rpx rgba(42, 62, 57, 0.08);
}

.pending-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F3E46;
}

.pending-card-item {
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: #60727B;
}

.primary-btn,
.secondary-btn {
  margin-top: 28rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 92rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #66BB6A 0%, #3F9C4B 100%);
  color: #FFFFFF;
  box-shadow: 0 14rpx 30rpx rgba(102, 187, 106, 0.24);
}

.secondary-btn {
  background: #FFFFFF;
  color: #4B5D65;
  border: 2rpx solid #D9E3DD;
}

.reply-role {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.reply-role.teacher {
  color: var(--primary-green-dark);
  background-color: var(--primary-green-light);
}

.reply-role.student {
  color: #607D8B;
  background-color: #ECEFF1;
}

/* 登录弹窗样式 */
.login-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.login-card {
  width: 600rpx;
  background: white;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: var(--text-main);
}

.login-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 40rpx;
}

.login-mark {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 30rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #90CAF9, #66BB6A);
  color: white;
  font-size: 56rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.nickname-input {
  width: 80%;
  height: 80rpx;
  background: #F5F7F5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  margin-bottom: 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.login-btn {
  width: 80% !important;
  height: 88rpx;
  background: var(--primary-green);
  color: white;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(102, 187, 106, 0.3);
}

.login-btn:active {
  transform: scale(0.98);
}

.login-btn[disabled] {
  background: #CFD8DC;
  box-shadow: none;
}

/* 详情弹窗样式 */
.detail-container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.detail-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  border-top-left-radius: 40rpx; /* page-container round 已处理，这里其实可以不需要 */
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.detail-scroll {
  flex: 1;
  padding: 20rpx 0;
  overflow-y: auto;
}

.detail-card {
  margin: 0 30rpx 30rpx;
}

.q-content.full {
  font-size: 34rpx;
  margin-bottom: 40rpx;
}

.q-info {
  display: flex;
  justify-content: space-between;
  color: #999;
  font-size: 24rpx;
}

.reply-section {
  padding: 0 30rpx 150rpx; /* 底部留白给输入框 */
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.reply-item {
  margin: 0 0 20rpx;
  padding: 24rpx;
}

.reply-user {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.reply-name {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.reply-time {
  font-size: 22rpx;
  color: #ccc;
}

.reply-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.reply-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.reply-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 18rpx;
  background: #E8F5E9;
}

.empty-reply {
  text-align: center;
  color: #ccc;
  padding: 40rpx 0;
  font-size: 26rpx;
}

/* 底部输入框 */
.reply-input-area {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}

.reply-compose {
  width: 100%;
}

.reply-compose-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.reply-preview-list {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
}

.reply-preview-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.reply-preview-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
}

.reply-preview-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.image-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E8F5E9;
  color: var(--primary-green-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.reply-input {
  flex: 1;
  background: #F5F7F5;
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-green), var(--primary-green-dark));
  box-shadow: 0 10rpx 24rpx rgba(102, 187, 106, 0.26);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn:active {
  transform: scale(0.96);
}

.send-icon {
  color: #FFFFFF;
  font-size: 34rpx;
  transform: translateX(2rpx) rotate(12deg);
}

/* 悬浮提问按钮 (FAB) */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-green), var(--primary-green-dark));
  box-shadow: 0 10rpx 30rpx rgba(102, 187, 106, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.3s ease;
}

.fab-btn text {
  color: white;
  font-size: 70rpx;
  font-weight: 200;
  margin-top: -10rpx; /* 微调垂直居中 */
  margin-left: 2rpx;  /* 微调水平居中 */
}

.fab-btn:active {
  transform: scale(0.95);
  box-shadow: 0 6rpx 20rpx rgba(102, 187, 106, 0.3);
}
