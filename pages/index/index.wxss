/* pages/index/index.wxss */
.banner {
  background: linear-gradient(135deg, var(--text-main), #455A64);
  padding: 60rpx 40rpx 80rpx; /* 底部留白给卡片上浮 */
  color: white;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  margin-bottom: -40rpx; /* 让第一个卡片上浮盖住 Banner */
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.85;
  font-weight: 300;
}

.search-bar {
  display: flex;
  align-items: center;
  margin: 0 30rpx 30rpx;
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  background-color: white;
  margin-top: -30rpx; /* 上浮 */
}

.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.85;
  font-weight: 300;
  margin-bottom: 20rpx; /* 增加底部间距 */
}

.search-input {
  flex: 1;
  margin-left: 20rpx;
  font-size: 28rpx;
  color: var(--text-main);
}

.sort-tabs {
  display: flex;
  margin: 0 30rpx 20rpx;
}

.tab-item {
  margin-right: 30rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 10rpx 0;
  position: relative;
}

.tab-item.active {
  color: var(--text-main);
  font-weight: bold;
  font-size: 30rpx;
}

.tab-item.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: var(--primary-green);
  border-radius: 4rpx;
}

.question-list {
  padding: 0 10rpx 40rpx;
}

.question-card {
  /* 继承 .card 样式并覆盖 */
  padding: 36rpx;
  margin-bottom: 24rpx;
  border: 1px solid rgba(0,0,0,0.02);
}

.q-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.q-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.q-user-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.q-time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #90CAF9, #66BB6A);
  color: white;
  font-weight: 700;
}

.avatar-placeholder.small {
  width: 56rpx;
  height: 56rpx;
  font-size: 24rpx;
}

.q-content {
  font-size: 32rpx;
  color: var(--text-main);
  margin-bottom: 30rpx;
  line-height: 1.7;
  text-align: justify;
}

.q-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid #F0F0F0;
  padding-top: 24rpx;
}

.q-status {
  font-size: 24rpx;
  display: flex;
  align-items: center;
}

.q-status::before {
  content: "";
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.q-status.replied {
  color: var(--primary-green);
}
.q-status.replied::before {
  background-color: var(--primary-green);
}

.q-status.pending {
  color: var(--accent-orange);
}
.q-status.pending::before {
  background-color: var(--accent-orange);
}

.q-actions {
  display: flex;
}

.action-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-left: 20rpx;
  display: flex;
  align-items: center;
}

.star-action.active,
.detail-star.active {
  color: #FFB300;
}

.q-reply {
  margin-top: 24rpx;
  background-color: #F9F9F9;
  padding: 20rpx;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.reply-label {
  color: var(--primary-green-dark);
  font-weight: bold;
}

.reply-role {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.reply-role.teacher {
  color: var(--primary-green-dark);
  background-color: var(--primary-green-light);
}

.reply-role.student {
  color: #607D8B;
  background-color: #ECEFF1;
}

/* 登录弹窗样式 */
.login-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.login-card {
  width: 600rpx;
  background: white;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: var(--text-main);
}

.login-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  width: 140rpx;
  height: 140rpx;
  padding: 0;
  background: none;
  border-radius: 50%;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.placeholder-avatar {
  width: 100%;
  height: 100%;
  font-size: 48rpx;
}

.nickname-input {
  width: 80%;
  height: 80rpx;
  background: #F5F7F5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  margin-bottom: 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.login-btn {
  width: 80% !important;
  height: 88rpx;
  background: var(--primary-green);
  color: white;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(102, 187, 106, 0.3);
}

.login-btn:active {
  transform: scale(0.98);
}

/* 详情弹窗样式 */
.detail-container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.detail-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  border-top-left-radius: 40rpx; /* page-container round 已处理，这里其实可以不需要 */
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.detail-scroll {
  flex: 1;
  padding: 20rpx 0;
  overflow-y: auto;
}

.detail-card {
  margin: 0 30rpx 30rpx;
}

.q-content.full {
  font-size: 34rpx;
  margin-bottom: 40rpx;
}

.q-info {
  display: flex;
  justify-content: space-between;
  color: #999;
  font-size: 24rpx;
}

.reply-section {
  padding: 0 30rpx 150rpx; /* 底部留白给输入框 */
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.reply-item {
  margin: 0 0 20rpx;
  padding: 24rpx;
}

.reply-user {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.reply-name {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.reply-time {
  font-size: 22rpx;
  color: #ccc;
}

.reply-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.reply-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.reply-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 18rpx;
  background: #E8F5E9;
}

.empty-reply {
  text-align: center;
  color: #ccc;
  padding: 40rpx 0;
  font-size: 26rpx;
}

/* 底部输入框 */
.reply-input-area {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}

.reply-compose {
  width: 100%;
}

.reply-compose-row {
  display: flex;
  align-items: center;
}

.reply-preview-list {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
}

.reply-preview-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.reply-preview-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
}

.reply-preview-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.image-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E8F5E9;
  color: var(--primary-green-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.reply-input {
  flex: 1;
  background: #F5F7F5;
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.send-btn {
  color: var(--primary-green);
  font-weight: bold;
  padding: 10rpx 20rpx;
}

/* 悬浮提问按钮 (FAB) */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-green), var(--primary-green-dark));
  box-shadow: 0 10rpx 30rpx rgba(102, 187, 106, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.3s ease;
}

.fab-btn text {
  color: white;
  font-size: 70rpx;
  font-weight: 200;
  margin-top: -10rpx; /* 微调垂直居中 */
  margin-left: 2rpx;  /* 微调水平居中 */
}

.fab-btn:active {
  transform: scale(0.95);
  box-shadow: 0 6rpx 20rpx rgba(102, 187, 106, 0.3);
}