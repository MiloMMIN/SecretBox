/* pages/index/index.wxss */
.banner {
  background-color: var(--primary-grey);
  padding: 40rpx 30rpx;
  color: white;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.8;
}

.question-list {
  padding-bottom: 40rpx;
}

.question-card {
  display: flex;
  flex-direction: column;
}

.q-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.q-tag {
  background-color: #eee;
  color: #666;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.q-time {
  font-size: 24rpx;
  color: #999;
}

.q-content {
  font-size: 32rpx;
  color: var(--text-main);
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.q-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid #f0f0f0;
  padding-top: 20rpx;
}

.q-status {
  font-size: 26rpx;
}

.q-status.replied {
  color: var(--primary-green);
}

.q-status.pending {
  color: var(--accent-orange);
}

.q-reply {
  margin-top: 20rpx;
  background-color: var(--bg-grey);
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.reply-label {
  font-weight: bold;
  color: var(--primary-green);
}

.empty-state {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
}
