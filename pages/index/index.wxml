<view class="container pending-page">
  <view class="pending-hero">
    <view class="pending-badge">待定功能</view>
    <view class="pending-title">问题广场暂未开放</view>
    <view class="pending-desc">公开互动模块正在重新规划。当前可继续使用私密投递与树洞信箱。</view>
  </view>

  <view class="pending-card">
    <view class="pending-card-title">当前可用</view>
    <view class="pending-card-item">向指定教师私密投递</view>
    <view class="pending-card-item">投递到星空树洞，由教师接力回复</view>
  </view>

  <button class="primary-btn" bindtap="goToDelivery">前往投递</button>
  <button class="secondary-btn" bindtap="goHome">返回欢迎页</button>
</view>
