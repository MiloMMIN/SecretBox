/* pages/profile/profile.wxss */
.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-role {
  font-size: 24rpx;
  background-color: #eee;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  display: inline-block;
  color: #666;
}

.role-switch-btn {
  font-size: 24rpx;
  margin: 0;
}

.menu-list {
  padding: 0 30rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1px solid #f0f0f0;
  font-size: 30rpx;
  color: var(--text-main);
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  color: #ccc;
}

.section-title {
  padding: 20rpx 30rpx 0;
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.dashboard-grid {
  display: flex;
  padding: 0 10rpx;
}

.grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.count {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-green);
  margin-bottom: 10rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
}

.badge {
  background-color: red;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.footer-info {
  text-align: center;
  margin-top: 60rpx;
  font-size: 24rpx;
  color: #ccc;
}
