/* pages/profile/profile.wxss */
.container {
  padding-bottom: 40rpx;
}

.user-card {
  display: flex;
  align-items: flex-start;
  padding: 50rpx 40rpx;
  margin: 0 20rpx 30rpx;
  background: linear-gradient(135deg, rgba(255, 251, 245, 0.96), rgba(244, 236, 223, 0.92));
  box-shadow: 0 18rpx 40rpx rgba(111, 89, 65, 0.08);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  width: 100%;
}

.user-name-input {
  width: 100%;
  max-width: 360rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  border-bottom: 1px dashed transparent;
  padding-bottom: 4rpx;
  transition: all 0.3s;
}

.user-name-input:focus {
  border-bottom-color: var(--primary-green);
}

.user-role-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.user-role {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  background: rgba(121, 150, 139, 0.14);
  color: #5f7a6f;
  align-self: flex-start;
}

.user-role.role-teacher {
  background: rgba(121, 150, 139, 0.14);
  color: #5f7a6f;
}

.user-role.role-student {
  background: rgba(214, 166, 120, 0.14);
  color: #bc7d4a;
}

.user-role.role-admin {
  background: rgba(93, 120, 111, 0.16);
  color: #4f6a62;
}

.user-role.role-super-admin {
  background: rgba(184, 106, 88, 0.16);
  color: #a85847;
}

.user-role.role-guest {
  background: rgba(160, 148, 135, 0.16);
  color: #8d7966;
}

.login-hint {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #7a6a5b;
  line-height: 1.6;
}

.login-btn {
  margin: 22rpx 0 0;
  width: 100%;
  max-width: 320rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #79968b, #5d786f);
  color: #fff;
  font-size: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(93, 120, 111, 0.18);
}

.login-btn[disabled] {
  opacity: 0.72;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #a8c2b1, #6b8a7d);
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
}

.menu-list {
  margin: 0 20rpx 30rpx;
  padding: 0 32rpx;
  background: rgba(255, 251, 245, 0.92);
  box-shadow: 0 18rpx 36rpx rgba(111, 89, 65, 0.08);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1px solid rgba(121, 150, 139, 0.08);
  font-size: 30rpx;
  color: var(--text-main);
  transition: background-color 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: rgba(121, 150, 139, 0.06);
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.arrow {
  color: #8fa39b;
  font-size: 32rpx;
  transition: transform 0.3s;
}

.arrow.up {
  transform: rotate(90deg);
}

.badge {
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d8a06f, #c87d4f);
  color: #fff;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
  font-weight: 600;
}

.sub-list {
  background-color: rgba(250, 246, 240, 0.9);
  padding: 10rpx 20rpx 18rpx;
  border-bottom: 1px solid rgba(121, 150, 139, 0.08);
}

.upgrade-input,
.upgrade-textarea {
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  border-radius: 16rpx;
  border: 1px solid rgba(121, 150, 139, 0.1);
  color: var(--text-main);
  font-size: 28rpx;
  margin: 8rpx 0 16rpx;
}

.upgrade-input {
  height: 80rpx;
  padding: 0 24rpx;
}

.upgrade-textarea {
  min-height: 150rpx;
  padding: 22rpx 24rpx;
}

.upgrade-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, #79968b, #5d786f);
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(93, 120, 111, 0.18);
}

.upgrade-btn[disabled] {
  opacity: 0.72;
}

.application-status-card {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1px solid rgba(121, 150, 139, 0.12);
}

.application-status-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.application-status-title {
  font-size: 26rpx;
  color: #44564f;
  font-weight: 600;
}

.application-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7a6a5b;
  line-height: 1.6;
}

.sub-item {
  padding: 20rpx 0;
  border-bottom: 1px dashed #e0e0e0;
}

.sub-item:last-child {
  border-bottom: none;
}

.sub-content {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.sub-time {
  font-size: 22rpx;
  color: #999;
}

.sub-status {
  display: inline-block;
  margin-top: 8rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.sub-status.replied,
.sub-status.approved {
  background-color: rgba(121, 150, 139, 0.14);
  color: #5f7a6f;
}

.sub-status.pending {
  background-color: rgba(214, 166, 120, 0.18);
  color: #bc7d4a;
}

.sub-status.rejected {
  background-color: rgba(190, 122, 96, 0.14);
  color: #b0604c;
}

.sub-detail {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #90a4ae;
}

.empty-sub {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.section-title {
  padding: 40rpx 40rpx 20rpx;
  font-size: 28rpx;
  color: #7b6b5c;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.teacher-panel-title {
  padding: 20rpx 0;
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 600;
}

.teacher-question-item {
  padding: 24rpx 0;
  border-bottom: 1px dashed #e0e0e0;
}

.teacher-question-item:last-child {
  border-bottom: none;
}

.teacher-question-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.teacher-question-time {
  font-size: 22rpx;
  color: #999;
}

.teacher-question-content {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.teacher-question-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #78909c;
}

.teacher-question-status {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.teacher-question-status.done {
  color: #5f7a6f;
  background: rgba(121, 150, 139, 0.14);
}

.teacher-question-status.todo {
  color: #bc7d4a;
  background: rgba(214, 166, 120, 0.18);
}

.teacher-question-latest {
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #607d8b;
  background: rgba(247, 243, 237, 0.92);
}

.teacher-question-action {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #5f7a6f;
}

.detail-container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: #fff;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.close-btn {
  font-size: 42rpx;
  color: #90a4ae;
}

.detail-scroll {
  flex: 1;
  padding: 24rpx;
}

.detail-card,
.detail-reply-item {
  margin-bottom: 20rpx;
}

.reply-section {
  padding-bottom: 30rpx;
}

.detail-content {
  font-size: 32rpx;
  line-height: 1.7;
  color: var(--text-main);
}

.detail-info {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  color: #90a4ae;
  font-size: 24rpx;
}

.detail-reply-user {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.detail-reply-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.detail-reply-name {
  font-size: 26rpx;
  color: #37474f;
  font-weight: 600;
}

.detail-reply-role {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.detail-reply-role.teacher {
  color: #5f7a6f;
  background-color: rgba(121, 150, 139, 0.14);
}

.detail-reply-role.student {
  color: #607d8b;
  background-color: #eceff1;
}

.detail-reply-time {
  margin-left: auto;
  font-size: 22rpx;
  color: #90a4ae;
}

.detail-reply-content {
  font-size: 28rpx;
  line-height: 1.7;
  color: #455a64;
}

.detail-reply-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.detail-reply-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
}

.reply-input-area {
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1px solid #eceff1;
}

.reply-compose {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reply-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.reply-preview-item {
  position: relative;
}

.reply-preview-image {
  width: 116rpx;
  height: 116rpx;
  border-radius: 18rpx;
}

.reply-preview-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reply-compose-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.image-btn,
.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.image-btn {
  background: #eceff1;
  color: #607d8b;
}

.send-btn {
  background: linear-gradient(135deg, var(--primary-green), var(--primary-green-dark));
  box-shadow: 0 10rpx 24rpx rgba(93, 120, 111, 0.26);
}

.reply-input {
  flex: 1;
  height: 76rpx;
  background: #f5f7f5;
  border-radius: 38rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text-main);
}

.send-btn:active {
  transform: scale(0.96);
}

.send-icon {
  color: #fff;
  font-size: 34rpx;
  transform: translateX(2rpx) rotate(12deg);
}

.secondary {
  margin-top: 16rpx;
  background: #eceff1;
  color: #455a64;
}

.export-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.export-card {
  width: 560rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
}

.export-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  text-align: center;
}

.export-desc {
  margin: 20rpx 0 30rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #78909c;
  text-align: center;
}

.export-close {
  margin-top: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #90a4ae;
}

.footer-info {
  margin-top: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #d8cfc6;
}
