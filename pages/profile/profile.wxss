/* pages/profile/profile.wxss */
.container {
  padding-bottom: 40rpx;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 50rpx 40rpx;
  background: linear-gradient(135deg, #FFF, #F9F9F9);
  margin-bottom: 30rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-right: 36rpx;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid white;
  box-shadow: var(--shadow-md);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #90CAF9, #66BB6A);
  color: white;
  font-size: 56rpx;
  font-weight: 700;
}

.edit-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: white;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-name-input {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-main);
  border-bottom: 1px dashed transparent;
  padding-bottom: 4rpx;
  transition: all 0.3s;
  width: 300rpx;
}

.user-name-input:focus {
  border-bottom-color: var(--primary-green);
}

.edit-hint {
  font-size: 28rpx;
  color: #ccc;
  margin-left: 10rpx;
}

.user-role {
  font-size: 24rpx;
  background-color: var(--primary-green-light);
  color: var(--primary-green-dark);
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  display: inline-block;
  font-weight: 500;
  align-self: flex-start;
}

.avatar-uploading-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #78909C;
}

.menu-list {
  padding: 0 40rpx;
  margin-bottom: 30rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1px solid #F5F5F5;
  font-size: 30rpx;
  color: var(--text-main);
  transition: background-color 0.2s;
}

.menu-item:active {
  background-color: #FAFAFA;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.arrow {
  color: #CFD8DC;
  font-size: 32rpx;
  transition: transform 0.3s;
}

.arrow.up {
  transform: rotate(90deg);
}

.sub-list {
  background-color: #FAFAFA;
  padding: 10rpx 20rpx;
  border-bottom: 1px solid #F5F5F5;
}

.upgrade-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  padding: 16rpx 0;
}

.upgrade-input {
  height: 80rpx;
  background: white;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin: 8rpx 0 16rpx;
}

.upgrade-btn {
  height: 72rpx;
  line-height: 72rpx;
  background: var(--primary-green);
  color: white;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.sub-item {
  padding: 20rpx 0;
  border-bottom: 1px dashed #E0E0E0;
}

.sub-item:last-child {
  border-bottom: none;
}

.sub-content {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.sub-time {
  font-size: 22rpx;
  color: #999;
}

.sub-status {
  font-size: 22rpx;
  margin-top: 8rpx;
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.sub-status.replied {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.sub-status.pending {
  background-color: #FFF3E0;
  color: #FF9800;
}

.sub-status.approved {
  background-color: #E8F5E9;
  color: #43A047;
}

.sub-status.rejected {
  background-color: #FFEBEE;
  color: #D32F2F;
}

.sub-detail {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #90A4AE;
}

.empty-sub {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.section-title {
  padding: 40rpx 40rpx 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: bold;
  letter-spacing: 1rpx;
}

.dashboard-grid {
  display: flex;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  border-radius: var(--radius-md);
  margin: 0 10rpx;
}

.teacher-panel-title {
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 600;
  padding: 20rpx 0;
}

.teacher-question-item {
  padding: 24rpx 0;
  border-bottom: 1px dashed #E0E0E0;
}

.teacher-question-item:last-child {
  border-bottom: none;
}

.teacher-question-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.teacher-question-type {
  padding: 6rpx 14rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
}

.teacher-question-type.public {
  color: #1565C0;
  background: #E3F2FD;
}

.teacher-question-type.private {
  color: var(--primary-green-dark);
  background: var(--primary-green-light);
}

.teacher-question-time {
  font-size: 22rpx;
  color: #999;
}

.teacher-question-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 12rpx;
}

.teacher-question-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #78909C;
}

.teacher-question-status {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.teacher-question-status.done {
  color: #43A047;
  background: #E8F5E9;
}

.teacher-question-status.todo {
  color: #FB8C00;
  background: #FFF3E0;
}

.teacher-question-latest {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #607D8B;
  background: #F5F7F5;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
}

.teacher-question-action {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #2E7D32;
}

.detail-container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.detail-header {
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: white;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.close-btn {
  font-size: 42rpx;
  color: #90A4AE;
}

.detail-scroll {
  flex: 1;
  padding: 24rpx;
}

.detail-card,
.detail-reply-item {
  margin-bottom: 20rpx;
}

.detail-content {
  font-size: 32rpx;
  line-height: 1.7;
  color: var(--text-main);
}

.detail-info {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  color: #90A4AE;
  font-size: 24rpx;
}

.detail-reply-user {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.detail-reply-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.detail-reply-name {
  font-size: 26rpx;
  color: #37474F;
  font-weight: 600;
}

.detail-reply-role {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.detail-reply-role.teacher {
  color: var(--primary-green-dark);
  background-color: var(--primary-green-light);
}

.detail-reply-role.student {
  color: #607D8B;
  background-color: #ECEFF1;
}

.detail-reply-time {
  margin-left: auto;
  font-size: 22rpx;
  color: #90A4AE;
}

.detail-reply-content {
  font-size: 28rpx;
  line-height: 1.7;
  color: #455A64;
}

.detail-reply-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.detail-reply-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
}

.reply-input-area {
  background: white;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #ECEFF1;
}

.reply-compose {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reply-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.reply-preview-item {
  position: relative;
}

.reply-preview-image {
  width: 116rpx;
  height: 116rpx;
  border-radius: 18rpx;
}

.reply-preview-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.65);
  color: white;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reply-compose-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.image-btn,
.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.image-btn {
  background: #ECEFF1;
  color: #607D8B;
}

.send-btn {
  background: var(--primary-green);
  color: white;
}

.reply-input {
  flex: 1;
  height: 76rpx;
  background: #F5F7F5;
  border-radius: 38rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text-main);
}

.count {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--primary-green);
  margin-bottom: 12rpx;
  font-family: 'DIN Alternate', sans-serif;
}

.label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.badge {
  background-color: var(--accent-red);
  color: white;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.secondary {
  margin-top: 16rpx;
  background: #ECEFF1;
  color: #455A64;
}

.export-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.export-card {
  width: 560rpx;
  background: white;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
}

.export-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  text-align: center;
}

.export-desc {
  margin: 20rpx 0 30rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #78909C;
  text-align: center;
}

.export-close {
  margin-top: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #90A4AE;
}

.footer-info {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #E0E0E0;
}
